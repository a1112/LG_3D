{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Motion Studio",
  "version": "0.1.0",
  "identifier": "com.bkvision.motionstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3015",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "涟钢3D端面检测系统",
        "width": 1500,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "transparent": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
